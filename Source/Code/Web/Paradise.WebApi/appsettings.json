{
  "$schema": "https://json.schemastore.org/appsettings.json",
  "AllowedHosts": "*",
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore.": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
      "Microsoft.EntityFrameworkCore.Infrastructure": "Warning"
    }
  },
  "OpenApiInfo": {
    "Contact": {
      "Email": "arthur.edgarov@bitharbor.dev",
      "Name": "Arthur Edgarov"
    },
    "Description": "This is a template for creating .NET back-end solutions<br>using a 3-layer architecture and Domain-Driven Design (DDD) pattern.<br>The template is built with Visual Studio and targets .NET 9.",
    "License": {
      "Name": "MIT",
      "Url": "https://spdx.org/licenses/MIT.html"
    },
    "Version": "v1"
  },
  "OpenApiSecurityScheme": {
    "BearerFormat": "A JWT prefixed with 'Bearer '.",
    "Description": "The authorization header is expected to contain the Bearer token.",
    "In": 1,
    "Name": "Authorization",
    "Reference": {
      "Id": "Bearer",
      "Type": 6
    },
    "Scheme": "Bearer",
    "Type": 1
  },
  "SwaggerEndpointName": "1.0",
  "SwaggerEndpointUrl": "/swagger/v1/swagger.json",
  "SwaggerUIOptions": {
    "DocumentTitle": "Paradise Api",
    "RoutePrefix": ""
  }
}