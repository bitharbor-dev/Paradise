{
  "$schema": "https://json.schemastore.org/appsettings.json",
  "AllowedHosts": "*",
  "AuthenticationOptions": {
    "AccessTokenLifetime": "00.00:05:00",
    "RefreshTokenLifetime": "90.00:00:00",
    "TwoFactorTokenLifetime": "00.01:00:00",
    "TwoFactorVerificationCodeLength": 6
  },
  "JwtBearerOptions": {
    "TokenValidationParameters": {
      "AuthenticationType": "Bearer",
      "ClockSkew": "0.00:00:00",
      "ValidateAudience": true,
      "ValidateIssuer": true,
      "ValidateIssuerSigningKey": true,
      "ValidateLifetime": true,
      "ValidAudience": "Paradise.WebApi",
      "ValidIssuer": "Paradise.WebApi"
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
    }
  },
  "OpenApiInfo": {
    "Contact": {
      "Email": "arthur.edgarov@bitharbor.dev",
      "Name": "Arthur Edgarov"
    },
    "Description": ".NET back-end solution template. Built with Visual Studio and targets .NET 10.",
    "License": {
      "Identifier": "MIT",
      "Name": "MIT"
    }
  },
  "OpenApiSecurityScheme": {
    "BearerFormat": "A JWT prefixed with 'Bearer '.",
    "Description": "The authorization header is expected to contain the Bearer token.",
    "In": 1,
    "Name": "Authorization",
    "Scheme": "bearer",
    "Type": 1
  },
  "RequestLocalizationOptions": {
    "ApplyCurrentCultureToResponseHeaders": true,
    "CultureInfoUseUserOverride": true,
    "DefaultRequestCulture": "en",
    "FallBackToParentCultures": true,
    "FallBackToParentUICultures": true,
    "SupportedCultures": [
      "en"
    ],
    "SupportedUICultures": [
      "en"
    ]
  },
  "ScalarOptions": {
    "DefaultOpenAllTags": false,
    "PersistentAuthentication": true,
    "ScalarAgentOptions": {
      "Disabled": true
    },
    "TagSorter": 0,
    "Theme": 0,
    "Title": "🌴 Paradise API"
  }
}