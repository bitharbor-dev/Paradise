@page "/reset-password/{IdentityToken}"
@model ResetPasswordModel

@{
    ViewData["Title"] = Localizer["Title"];
}

<main class="container">
    @if (Model.IsSuccess)
    {
        <div class="success-overlay">
            <div class="card">
                <h2>@Localizer["SuccessMessageHeader"]</h2>
                <p class="subtitle">@Localizer["SuccessMessage"]</p>
            </div>
        </div>
    }
    else
    {
        <div class="card">

            <h2>@Localizer["CardHeader"]</h2>
            <p class="subtitle">@Localizer["CardSubtitle"]</p>

            <form method="post" id="reset-form">
                @Html.AntiForgeryToken()

                <div class="form-group">
                    <label asp-for="Password">@Localizer["LabelPassword"]</label>
                    <input asp-for="Password" type="password" id="password" />
                </div>

                <div class="form-group">
                    <label asp-for="PasswordConfirmation">@Localizer["LabelPasswordConfirmation"]</label>
                    <input asp-for="PasswordConfirmation" type="password" id="confirm-password" />
                </div>

                <ul id="requirements-list">
                    <li data-requirement="length" class="invalid">@Localizer["RuleLength"]</li>
                    <li data-requirement="uppercase" class="invalid">@Localizer["RuleUppercase"]</li>
                    <li data-requirement="lowercase" class="invalid">@Localizer["RuleLowercase"]</li>
                    <li data-requirement="number" class="invalid">@Localizer["RuleNumber"]</li>
                    <li data-requirement="special" class="invalid">@Localizer["RuleSpecial"]</li>
                </ul>

                @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                {
                    <div class="error-message">
                        @Model.ErrorMessage
                    </div>
                }

                <button type="submit" id="submit-btn" disabled>@Localizer["SubmitButton"]</button>

            </form>
        </div>
    }
</main>

<script src="~/Pages/ResetPassword.cshtml.js"></script>