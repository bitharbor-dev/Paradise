<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<PackageType>Template</PackageType>
		<PackageId>BitHarbor.WebApplicationTemplate.Paradise</PackageId>
		<PackageTags>dotnet-new;template;paradise</PackageTags>
		<PackageVersion>1.0.0</PackageVersion>
		<PackageProjectUrl>https://github.com/bitharbor-dev/Paradise</PackageProjectUrl>
		<PackageLicenseExpression>MIT</PackageLicenseExpression>
	</PropertyGroup>

	<PropertyGroup>
		<TargetFramework>net10.0</TargetFramework>
		<NoWarn>$(NoWarn);NU5123;NU5128</NoWarn>
	</PropertyGroup>

	<PropertyGroup>
		<Title>Bit Harbor web API template</Title>
		<Authors>Bit Harbor</Authors>
		<Description>An open-source back-end application template.</Description>
	</PropertyGroup>

	<PropertyGroup>
		<IncludeBuildOutput>False</IncludeBuildOutput>
		<ContentTargetFolders>content</ContentTargetFolders>
		<NoDefaultExcludes>True</NoDefaultExcludes>
	</PropertyGroup>

	<ItemGroup>
		<Content Include="content\**\*" Exclude="content\**\.bin\**;content\**\.obj\**" />
		<Compile Remove="**\*" />
	</ItemGroup>

</Project>